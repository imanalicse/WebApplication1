@model IEnumerable<WebApplication1.Models.Book>

@{
    ViewData["Title"] = "Books";
}

<h1>Books</h1>
<table class="table">
    <thead>
        <tr>
            <th>Id</th>
            <th>Title</th>
            <th>Author</th>
            <th>Year</th>
            <th>Tags</th>
        </tr>
    </thead>
    <tbody>
@foreach (var b in Model)
{
    <tr>
        <td>@b.Id</td>
        <td>@b.Title</td>
        <td>@b.Author</td>
        <td>@b.Year</td>
        <td>@(b.Tags == null ? "" : string.Join(", ", b.Tags))</td>
    </tr>
}
    </tbody>
</table>
